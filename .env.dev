# 도커 빌드용 환경변수
# docker-compose.override.yml이 자동으로 적용
# docker-compose up --build -d
# ============================================
# common

SPRING_PROFILES_ACTIVE=dev
DOMAIN=http://localhost:8081

SECURITY_ORIGIN_ALLOWLIST=http://localhost:5173,http://localhost:8081,http://localhost:8082
SECURITY_COOKIE_SECURE=false

OBJECT_STORAGE_ENDPOINT=http://host.docker.internal:9000
OBJECT_STORAGE_REGION=ap-seoul-1
OBJECT_STORAGE_BUCKET=mocktalk
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_PATH_STYLE_ACCESS=true
OBJECT_STORAGE_KEY_PREFIX=uploads
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_PRESIGN_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PRESIGN_EXPIRE_SECONDS=300
OBJECT_STORAGE_UPLOAD_PROXY_PREFIX=/storage
UPLOAD_SESSION_TTL_SECONDS=600
UPLOAD_ORPHAN_CLEANUP_GRACE_SECONDS=120
UPLOAD_ORPHAN_CLEANUP_INTERVAL_MS=300000
UPLOAD_ORPHAN_CLEANUP_BATCH_SIZE=200
STORAGE_DELETE_RETRY_ENABLED=true
STORAGE_DELETE_RETRY_INTERVAL_MS=30000
STORAGE_DELETE_RETRY_BATCH_SIZE=200
STORAGE_DELETE_RETRY_INITIAL_DELAY_SEC=30
STORAGE_DELETE_RETRY_MAX_DELAY_SEC=3600
STORAGE_DELETE_RETRY_MAX_ATTEMPTS=10
STORAGE_DELETE_DLQ_RETENTION_SEC=2592000
APP_FILE_TEMP_EXPIRE_HOURS=24
APP_FILE_TEMP_CLEANUP_INTERVAL_MS=3600000

MANAGEMENT_PORT=8083
MANAGEMENT_ADDRESS=0.0.0.0

JWT_SECRET=mocktalk-dev-secret-key-at-least-32-bytes  # 32+ chars
JWT_ISSUER=mocktalk
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
JWT_REFRESH_ABSOLUTE_TTL_SECONDS=2592000

GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy
GITHUB_CLIENT_ID=dummy
GITHUB_CLIENT_SECRET=dummy

OAUTH2_CODE_TTL_SECONDS=60
OAUTH2_REMEMBER_ME_DEFAULT=false
# OAUTH2_REDIRECT_PATH=/oauth/callback
OAUTH2_REDIRECT_PATH=http://localhost:8081/oauth/callback

# dev
SERVER_PORT=8082
DB_DRIVER_CLASS_NAME=org.postgresql.Driver
DB_URL=jdbc:postgresql://host.docker.internal:5432/mocktalk
DB_USERNAME=mocktalk
DB_PASSWORD=1234
# JPA_DIALECT=org.hibernate.dialect.MariaDBDialect
# JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
REDIS_HOST=host.docker.internal  # 도커이미지간 연결 일 경우
REDIS_PORT=6379
REDIS_PASSWORD=

HTML_ALLOWED_FILE_ORIGINS=http://localhost:9000,http://localhost:8082
HTML_ALLOWED_IFRAME_PREFIXES=https://www.youtube.com/embed,https://www.youtube-nocookie.com/embed


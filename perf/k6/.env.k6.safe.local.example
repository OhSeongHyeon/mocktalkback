# k6 운영 안전 모드 로컬 템플릿
# 사용 방법:
# 1) 이 파일을 .env.k6.safe.local 로 복사
# 2) 아래 값을 본인 운영/스테이징 정보로 교체
# 3) source 로딩 후 k6 실행

# =========================
# 공통 필수값
# =========================

# 예: https://app.mocktalk.site
BASE_URL=https://your-domain.example.com

# 테스트 전용 계정(운영 사용자 계정 사용 금지)
K6_LOGIN_ID=your_test_login_id
K6_PASSWORD=your_test_password
# 다중 사용자 fan-out 시나리오용 계정 풀(선택)
# 형식: login1:password1,login2:password2
K6_LOGIN_USERS=

# 테스트 전용 데이터 ID
K6_ARTICLE_ID=1
K6_COMMENT_ID=1
K6_SEARCH_QUERY=공지
K6_SEARCH_SIZE=10
K6_TREND_LIMIT=10

# 익명 사용자 시나리오 헤더
K6_ANON_IP_FIXED=198.51.100.10
K6_ANON_USER_AGENT_FIXED=k6-anon-fixed/1.0
K6_ANON_IP_PREFIX=198.51.100
K6_ANON_USER_AGENT_PREFIX=k6-anon-rotating

# =========================
# 운영 안전 기본 강도(저강도)
# =========================

# article.unit.load.js
K6_VUS_ARTICLE_READ=1
K6_DURATION_ARTICLE_READ=15s
K6_VUS_ARTICLE_REACTION=1
K6_DURATION_ARTICLE_REACTION=15s
K6_START_ARTICLE_REACTION=20s

# article.view.load.js
K6_VUS_ARTICLE_SAME_USER=1
K6_DURATION_ARTICLE_SAME_USER=15s
K6_VUS_ARTICLE_MULTI_USER=0
K6_ITERATIONS_ARTICLE_MULTI_USER=1
K6_MAX_DURATION_ARTICLE_MULTI_USER=20s
K6_START_ARTICLE_MULTI_USER=20s
K6_VUS_ARTICLE_ANON_FIXED=1
K6_DURATION_ARTICLE_ANON_FIXED=15s
K6_START_ARTICLE_ANON_FIXED=40s
K6_VUS_ARTICLE_ANON_IP_ROTATE=0
K6_ITERATIONS_ARTICLE_ANON_IP_ROTATE=1
K6_MAX_DURATION_ARTICLE_ANON_IP_ROTATE=20s
K6_START_ARTICLE_ANON_IP_ROTATE=60s
K6_VUS_ARTICLE_ANON_UA_ROTATE=0
K6_ITERATIONS_ARTICLE_ANON_UA_ROTATE=1
K6_MAX_DURATION_ARTICLE_ANON_UA_ROTATE=20s
K6_START_ARTICLE_ANON_UA_ROTATE=80s

# article.trending.load.js
K6_VUS_ARTICLE_TREND_EVENT_MIX=1
K6_DURATION_ARTICLE_TREND_EVENT_MIX=20s
K6_VUS_ARTICLE_TREND_READ=1
K6_DURATION_ARTICLE_TREND_READ=20s
K6_START_ARTICLE_TREND_READ=5s

# comment.unit.load.js
K6_VUS_COMMENT_LIST=1
K6_DURATION_COMMENT_LIST=15s
K6_VUS_COMMENT_SNAPSHOT=1
K6_DURATION_COMMENT_SNAPSHOT=15s
K6_START_COMMENT_SNAPSHOT=20s
K6_VUS_COMMENT_REACTION=1
K6_DURATION_COMMENT_REACTION=15s
K6_START_COMMENT_REACTION=40s

# search.unit.load.js
K6_VUS_SEARCH_ALL=1
K6_DURATION_SEARCH_ALL=15s
K6_VUS_SEARCH_ARTICLE=1
K6_DURATION_SEARCH_ARTICLE=15s
K6_START_SEARCH_ARTICLE=20s
K6_VUS_SEARCH_COMMENT=1
K6_DURATION_SEARCH_COMMENT=15s
K6_START_SEARCH_COMMENT=40s

# integration.load.js
K6_VUS_SNAPSHOT=1
K6_DURATION_SNAPSHOT=15s
K6_START_SNAPSHOT=40s
K6_START_SEARCH_ALL=60s

# =========================
# 권장 운영 수칙
# =========================
# - 비피크 시간에 실행
# - 5xx 증가/에러율 급증 시 즉시 중단
# - 테스트 후 생성/변경 데이터 정리
